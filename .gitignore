# --- CTF Professor Specific ---

# Security: Never commit environment variables and secrets
.env
.env.local
.env.*
mcp_config.json

# Local Challenge Workspace
# We ignore everything inside CTFs/ to prevent leaking challenge binaries, 
# memory dumps, or solved flags, but we keep the folder structure if needed.
CTFs/*
!CTFs/.gitkeep

# Ignore common CTF artifacts that might be dropped in the root by accident
*.pcap
*.pcapng
*.dmp
*.vmem
*.raw
*.elf
*.bin
*.exe
*.dll
*.apk
# Ignore flag files that might be accidentally created in root
flag.txt
flag
